# ============================================================
# Dockerfile Jetson Orin / ARM64
# Ubuntu 22.04 + ROS 2 Humble + Qt/PySide6 + LCM
#
# Imagen reducida para lanzar Fixposition + TF + robot_state_publisher.
# En el perfil local usamos Fast DDS por defecto porque en este workspace
# CycloneDDS deja trafico ROS 2 a medias: permite leer topics, pero no publica
# de vuelta al PC de forma fiable y algunos servicios quedan colgados.
# ============================================================

FROM ubuntu:22.04

SHELL ["/bin/bash", "-c"]

ARG ROS_DISTRO=humble

ENV ROS_DISTRO=${ROS_DISTRO}
ENV DEBIAN_FRONTEND=noninteractive
ENV LANG=en_US.UTF-8
ENV LC_ALL=en_US.UTF-8
ENV SETUPTOOLS_USE_DISTUTILS=stdlib
ENV ROS_LOCALHOST_ONLY=0
ENV QT_X11_NO_MITSHM=1
ENV QTWEBENGINE_DISABLE_SANDBOX=1
ENV LIBGL_ALWAYS_SOFTWARE=1
ENV MESA_LOADER_DRIVER_OVERRIDE=llvmpipe
ENV QTWEBENGINE_CHROMIUM_FLAGS="--disable-gpu --disable-dev-shm-usage"

RUN apt-get update && \
    apt-get install -y --no-install-recommends \
      locales \
      curl \
      gnupg \
      lsb-release \
      ca-certificates \
      software-properties-common \
      build-essential \
      git \
      cmake \
      ninja-build \
      pkg-config \
      python3-dev \
      python3-pip \
      python3-distutils \
      xauth \
      libglib2.0-0 \
      libglib2.0-dev \
      libgl1-mesa-glx \
      libgl1-mesa-dri \
      mesa-utils \
      libxcb-cursor0 \
      libxkbcommon-x11-0 \
      libxcb-xinerama0 \
      libxcb-icccm4 \
      libxcb-image0 \
      libxcb-keysyms1 \
      libxcb-render-util0 \
      libxcb-randr0 \
      libxcb-shape0 \
      libxcb-xfixes0 \
      libxcb-sync1 \
      libx11-xcb1 \
      libxkbfile1 \
      libnss3 \
      libnspr4 \
      libasound2 \
      libxdamage1 \
      libxrandr2 \
      libxcomposite1 \
      libxshmfence1 \
      libgbm1 \
      libdrm2 \
      libatk1.0-0 \
      libatk-bridge2.0-0 \
      libcups2 \
      libgtk-3-0 \
      dbus \
      dbus-x11 \
      iproute2 \
      iputils-ping \
      net-tools \
      gettext-base \
      procps \
      vim \
      nano \
      less \
    && locale-gen en_US.UTF-8 \
    && add-apt-repository -y universe \
    && rm -rf /var/lib/apt/lists/*

RUN install -d /etc/apt/keyrings && \
    curl -fsSL https://raw.githubusercontent.com/ros/rosdistro/master/ros.key \
      | gpg --dearmor -o /etc/apt/keyrings/ros2.gpg && \
    echo "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/ros2.gpg] http://packages.ros.org/ros2/ubuntu $(lsb_release -cs) main" \
      > /etc/apt/sources.list.d/ros2.list

RUN apt-get update && \
    apt-get install -y --no-install-recommends \
      ros-${ROS_DISTRO}-ros-base \
  ros-${ROS_DISTRO}-angles \
      ros-${ROS_DISTRO}-rmw-fastrtps-cpp \
      ros-${ROS_DISTRO}-rmw-cyclonedds-cpp \
      ros-${ROS_DISTRO}-ament-cmake \
      ros-${ROS_DISTRO}-rosidl-default-generators \
      ros-${ROS_DISTRO}-xacro \
      ros-${ROS_DISTRO}-robot-state-publisher \
      ros-${ROS_DISTRO}-joint-state-publisher \
      ros-${ROS_DISTRO}-tf2-ros \
      ros-humble-rmw-cyclonedds-cpp \
      python3-colcon-common-extensions \
      python3-vcstool \
      python3-rosdep \
      python3-requests \
      geographiclib-tools \
      libgeographic-dev \
      libopencv-dev \
      libpcl-dev \
      libnanoflann-dev \
      libopenblas0 \
      libopenblas-dev \
      liblapack-dev \
    && (rosdep init || true) \
    && rosdep update \
    && rm -rf /var/lib/apt/lists/*

RUN git clone --depth 1 --branch v1.5.0 https://github.com/lcm-proj/lcm.git /tmp/lcm && \
    cmake -S /tmp/lcm -B /tmp/lcm/build -G Ninja \
      -DCMAKE_INSTALL_PREFIX=/usr \
      -DCMAKE_BUILD_TYPE=Release && \
    cmake --build /tmp/lcm/build && \
    cmake --install /tmp/lcm/build && \
    ldconfig && \
    rm -rf /tmp/lcm

RUN python3 -m pip install --no-cache-dir --upgrade \
      pip \
      "setuptools~=69.5" \
      packaging \
      wheel && \
    python3 -m pip install --no-cache-dir \
      "numpy<1.24" \
      "PySide6~=6.5" \
      "Cython~=0.29" \
      utm \
      pyproj \
      cvxpy

WORKDIR /ros2_ws

COPY src ./src

RUN bash -lc "apt-get update && \
        source /opt/ros/humble/setup.bash && \
        rosdep install --from-paths src --ignore-src -r -y \
            --rosdistro humble \
            --skip-keys='pcl' && \
        rm -rf /var/lib/apt/lists/*"

# 7. Compilar
# Eliminar artefactos de build/install que pudieran haberse copiado desde el
# host (contienen rutas absolutas) para forzar una compilación limpia en la
# imagen y evitar que CMake use paths del sistema host.
# ENV RMW_IMPLEMENTATION=rmw_fastrtps_cpp
# ENV ROS_DOMAIN_ID=0

# # Copiar configuración FastDDS para comunicación entre contenedores
# COPY fastdds_host.xml /root/fastdds_host.xml
# ENV FASTRTPS_DEFAULT_PROFILES_FILE=/root/fastdds_host.xml

RUN /bin/bash -c "source /opt/ros/$ROS_DISTRO/setup.bash && \
  colcon build --parallel-workers $(nproc) --symlink-install \
  --event-handlers console_direct+ --base-paths src \
  --cmake-args ' -DCMAKE_BUILD_TYPE=Release' \
  ' -DCMAKE_LIBRARY_PATH=/usr/local/cuda/lib64/stubs' \
  ' -DCMAKE_CXX_FLAGS="-Wl,--allow-shlib-undefined"' \
  ' --no-warn-unused-cli' "

RUN mkdir -p /etc/cyclonedds
COPY local_cyclonedds.xml /etc/cyclonedds/local_cyclonedds.template.xml
ENV CYCLONEDDS_URI=file:///etc/cyclonedds/local_cyclonedds.xml
ENV DDS_IP=192.168.1.117
ENV RMW_IMPLEMENTATION=rmw_cyclonedds_cpp

COPY entrypoint_local.sh /entrypoint.sh

RUN chmod +x /entrypoint.sh

ENTRYPOINT ["/entrypoint.sh"]
CMD ["bash"]